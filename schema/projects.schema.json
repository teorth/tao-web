{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://terrytao.github.io/tao-web/schema/projects.schema.json",
  "title": "Collaborative projects",
  "description": "Online collaborative/formalization projects, rendered as a page grouped by status.",
  "type": "object",
  "additionalProperties": false,
  "required": ["projects"],
  "properties": {
    "title": { "type": "string" },
    "description": { "type": "string", "description": "Intro prose for the page." },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "launched", "repo", "status"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string", "description": "One-sentence summary." },
          "launched": { "type": "integer", "description": "Year the project was launched." },
          "repo": { "type": "string", "description": "Source repository URL." },
          "url": { "type": "string", "description": "Project site/blueprint (optional)." },
          "status": {
            "type": "string",
            "enum": ["active", "inactive"],
            "description": "active, or inactive (completed/paused)."
          }
        }
      }
    }
  }
}
