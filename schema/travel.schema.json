{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://terrytao.github.io/tao-web/schema/travel.schema.json",
  "title": "Travel log",
  "description": "Upcoming and past travel/speaking engagements, rendered as a chronological travel page.",
  "type": "object",
  "additionalProperties": false,
  "required": ["upcoming", "past"],
  "properties": {
    "title": { "type": "string" },
    "note": { "type": "string", "description": "Standing note shown above the upcoming list." },
    "upcoming": { "type": "array", "items": { "$ref": "#/$defs/trip" } },
    "past": { "type": "array", "items": { "$ref": "#/$defs/trip" } }
  },
  "$defs": {
    "trip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["year", "dates", "place"],
      "properties": {
        "year": { "type": "integer", "description": "Start year (used for grouping/sorting)." },
        "dates": { "type": "string", "description": "Display date or date range, e.g. \"May 11–15\"." },
        "place": { "type": "string", "description": "Destination (may include a short descriptor)." },
        "url": { "type": "string", "description": "Optional link (event page, often web.archive.org)." },
        "cancelled": { "type": "boolean", "description": "Trip was cancelled (shown struck through)." },
        "tentative": { "type": "boolean", "description": "Trip is tentative." },
        "note": { "type": "string", "description": "Short qualifier, e.g. \"very tentative\"." }
      }
    }
  }
}
