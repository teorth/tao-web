{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://terrytao.github.io/tao-web/schema/teaching.schema.json",
  "title": "Teaching (course list)",
  "description": "Past (and current) courses, rendered as a collapsible Teaching section on the index.",
  "type": "object",
  "additionalProperties": false,
  "required": ["courses"],
  "properties": {
    "title": { "type": "string" },
    "courses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["year", "quarter", "number", "title"],
        "properties": {
          "year": { "type": "integer", "description": "Calendar year of the term." },
          "quarter": {
            "type": "string",
            "enum": ["F", "W", "S", "Su"],
            "description": "Term: F=Fall, W=Winter, S=Spring, Su=Summer."
          },
          "number": { "type": "string", "minLength": 1, "description": "Course number, e.g. \"Math 246A\"." },
          "title": { "type": "string", "minLength": 1, "description": "Course subject, e.g. \"Complex analysis\"." },
          "institution": { "type": "string", "description": "Institution if not UCLA (e.g. \"UNSW\", \"ANU\")." },
          "term": { "type": "string", "description": "Display override for non-quarter terms, e.g. \"Semester 2\" (quarter is still used for sorting)." },
          "url": { "type": "string", "description": "Link to the course page (optional; some old courses have none)." }
        }
      }
    }
  }
}
